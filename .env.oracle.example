# ==========================================
# ORACLE CLOUD VM DEPLOYMENT (Ghost + Aiven MySQL + Brevo)
# ==========================================
# Copy this file to .env on the VM and fill in the real values.
# NEVER commit the real .env (it is gitignored).
#
# Difference from the Render setup: the Oracle VM does NOT block SMTP port
# 587, so we use Brevo on the standard 587 (STARTTLS). Port 2525 still works
# as a fallback if needed.

# --- Site URL ---
# Initially the VM public IP over HTTP (e.g. http://123.45.67.89).
# Change to https://your-domain.com once a domain + TLS proxy is in place,
# then recreate the container.
url=http://PUBLIC_IP_HERE

# --- Node ---
NODE_ENV=production

# --- Database (Aiven MySQL) ---
database__client=mysql
database__connection__host=YOUR_HOST.aivencloud.com
database__connection__port=YOUR_PORT
database__connection__user=avnadmin
database__connection__password=YOUR_AIVEN_PASSWORD
database__connection__database=defaultdb
database__connection__ssl__rejectUnauthorized=false

# --- Mail (Brevo SMTP) ---
mail__transport=SMTP
mail__from=WarZ Tech News <no-reply@your-domain.com>
mail__options__host=smtp-relay.brevo.com
mail__options__port=587
mail__options__secure=false
mail__options__auth__user=YOUR_BREVO_SMTP_LOGIN
mail__options__auth__pass=YOUR_BREVO_SMTP_KEY
