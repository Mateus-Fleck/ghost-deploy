# WarZ Tech News - Ghost Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ==========================================
# RAILWAY DEPLOYMENT
# ==========================================
# These variables will be set automatically by Railway
# You just need to reference them in Railway dashboard

# Site URL (will be provided by Railway)
url=https://warztech.up.railway.app

# Database Configuration (MySQL from Railway)
database__client=mysql
database__connection__host=${{MySQL.MYSQL_HOST}}
database__connection__port=${{MySQL.MYSQL_PORT}}
database__connection__user=${{MySQL.MYSQL_USER}}
database__connection__password=${{MySQL.MYSQL_PASSWORD}}
database__connection__database=${{MySQL.MYSQL_DATABASE}}

# Node Environment
NODE_ENV=production

# Mail Configuration (optional - can configure later in Ghost admin)
# mail__transport=SMTP
# mail__options__service=Mailgun
# mail__options__host=smtp.mailgun.org
# mail__options__port=587
# mail__options__auth__user=postmaster@warztech.news
# mail__options__auth__pass=YOUR_MAILGUN_PASSWORD

# ==========================================
# LOCAL DEVELOPMENT (if using docker-compose)
# ==========================================
# url=http://localhost:2368
# database__client=sqlite3
# database__connection__filename=/var/lib/ghost/content/data/ghost.db
# NODE_ENV=development
