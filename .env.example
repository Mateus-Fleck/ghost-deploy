# WarZ Tech News - Ghost Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ==========================================
# RENDER (WEB SERVICE) + AIVEN (MYSQL) DEPLOYMENT
# ==========================================
# O Ghost roda no Render, mas o banco MySQL roda no Aiven
# (o Render nao oferece MySQL gerenciado, so Postgres).
#
# Estas variaveis devem ser configuradas manualmente no Render Dashboard
# (aba Environment do servico warztech-ghost), nao neste arquivo.
# Pegue os valores em: Aiven Console > seu servico MySQL > Overview >
# Connection information.

# Site URL (a URL final gerada pelo Render, ex: https://warztech-ghost.onrender.com)
url=https://warztech-ghost.onrender.com

# Database Configuration (MySQL do Aiven)
database__client=mysql
database__connection__host=SEU_HOST.aivencloud.com
database__connection__port=SUA_PORTA
database__connection__user=avnadmin
database__connection__password=SUA_SENHA_AIVEN
database__connection__database=defaultdb

# Aiven exige SSL. rejectUnauthorized=false mantem a conexao criptografada
# sem exigir o certificado CA (mais simples de configurar que ssl__ca).
database__connection__ssl__rejectUnauthorized=false

# Node Environment
NODE_ENV=production

# Mail Configuration (optional - can configure later in Ghost admin)
# mail__transport=SMTP
# mail__options__service=Mailgun
# mail__options__host=smtp.mailgun.org
# mail__options__port=587
# mail__options__auth__user=postmaster@warztech.news
# mail__options__auth__pass=YOUR_MAILGUN_PASSWORD

# ==========================================
# LOCAL DEVELOPMENT (if using docker-compose)
# ==========================================
# url=http://localhost:2368
# database__client=sqlite3
# database__connection__filename=/var/lib/ghost/content/data/ghost.db
# NODE_ENV=development
